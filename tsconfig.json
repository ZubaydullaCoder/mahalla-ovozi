{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "NodeNext",
    "moduleResolution":  "NodeNext",
    "lib":               ["ES2022"],
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true,
    "resolveJsonModule": true
  },
  "include": [
    "apps/server/src/**/*.ts",
    "eval/**/*.ts",
    "packages/contracts/src/**/*.ts",
    "prisma/**/*.ts",
    "prisma.config.ts",
    "scripts/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules"]
}
