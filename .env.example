# Database — treat as secret (contains credentials)
DATABASE_URL=postgresql://mahalla:devpassword@localhost:5432/mahalla_ovozi

# Session
SESSION_SECRET=change_this_to_a_random_string_in_production # production requires a random 32+ character value

# Telegram Bot
BOT_TOKEN=                      # from @BotFather
TELEGRAM_WEBHOOK_SECRET=        # random string; same in Telegram webhook config

# AI
AI_PROVIDER=gemini              # gemini | ollama | openai-compatible | rule-only
AI_API_KEY=                     # required for gemini/openai-compatible; leave blank for ollama/rule-only
AI_MODEL=gemini-2.5-flash       # provider model; set a non-Gemini model for ollama/openai-compatible
AI_BASE_URL=                    # optional for ollama; required for openai-compatible (example: http://127.0.0.1:11434/api for local Ollama/Gemma, or http://localhost:1234/v1)
AI_TIMEOUT_MS=30000             # per-classification provider timeout
CLASSIFIER_BATCH_SIZE=100       # max raw messages processed per classifier run
CLASSIFIER_AUTO_TRIGGER_ENABLED=true # trigger background classifier drain after keyword-matched webhook intake
CLASSIFIER_CRON=* * * * *       # lightweight classifier fallback cron; default every minute

# Pipeline
FILTER_MODE=keyword_gate        # current active filtering method

# Ops Console
OPS_ENABLED=false               # true only during Phase 1 local HITL validation
OPS_SECRET=                     # optional; required if accessing Ops Console over a tunnel

# Server
NODE_ENV=development
PORT=3001
